{
  "name": "@bukkentime/japanese-numeral",
  "version": "1.1.0-rc.1",
  "description": "Converts Japanese Kanji numeral to number.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm test && npm run build",
    "test": "mocha -r ts-node/register test/*.ts",
    "test:watch": "npm test -- --watch --watch-files src/**/*.ts --watch-files test/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geolonia/japanese-numeral.git"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "author": "Geolonia Inc.",
  "license": "MIT",
  "devDependencies": {
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "chai": "^4.3.8",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
